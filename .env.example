# App
APP_NAME=ai-service
APP_ENV=development
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Redis (cho Phase 6)
REDIS_URL=redis://localhost:6379/0

# Storage (cho Phase 1)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=ai-service

# AI (Phase 1–3)
MODEL_PATH=ml/weights/yolov8n.pt
MODEL_VERSION=v0.1.0-yolov8n
INFERENCE_TIMEOUT_SECONDS=4.5
CLASSIFICATION_CONFIDENCE_AUTO=0.8
CLASSIFICATION_CONFIDENCE_SUGGEST_LOW=0.5
# BR-AI-003 v1 severity bands (coverage ratio upper edges 0.05 / 0.15 / 0.40)
SEVERITY_COVER_LOW_BELOW=0.05
SEVERITY_COVER_MEDIUM_BELOW=0.15
SEVERITY_COVER_HIGH_BELOW=0.40
# Mapped pollution box confidence floor để gán POLLUTION_LIKELY
RELEVANCE_MIN_CONFIDENCE=0.3
SUSPICIOUS_EDIT_TIME_DIFF_HOURS=1.0
DUPLICATE_PHASH_SIMILARITY_THRESHOLD=0.85
DUPLICATE_MAX_DISTANCE_METERS=50.0
DUPLICATE_MAX_TIME_DIFF_HOURS=24.0
STORAGE_STUB_MODE=true
# Bật khi CHƯA có file MODEL_PATH để trang demo hiện ví dụ SUGGEST/TRASH (chỉ môi trường thử — tắt trên prod)
CLASSIFY_DEMO_MODE=false

# Scene Classifier (EfficientNet-B0) — để trống để tắt, set sau khi train xong
SCENE_CLASSIFIER_PATH=
SCENE_CLASSIFIER_VERSION=v1.0.0-scene-classifier
SCENE_CLASSIFIER_THRESHOLD=0.45
